{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockConverseAccess",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream",
        "bedrock:Converse",
        "bedrock:ConverseStream"
      ],
      "Resource": [
        "arn:aws-us-gov:bedrock:us-gov-west-1::foundation-model/*"
      ]
    },
    {
      "Sid": "BedrockKnowledgeBaseRetrieve",
      "Effect": "Allow",
      "Action": [
        "bedrock:Retrieve",
        "bedrock:RetrieveAndGenerate"
      ],
      "Resource": [
        "arn:aws-us-gov:bedrock:us-gov-west-1:ACCOUNT_ID:knowledge-base/KB_ID"
      ]
    },
    {
      "Sid": "BedrockIngestionJobManagement",
      "Effect": "Allow",
      "Action": [
        "bedrock:StartIngestionJob",
        "bedrock:GetIngestionJob",
        "bedrock:ListIngestionJobs"
      ],
      "Resource": [
        "arn:aws-us-gov:bedrock:us-gov-west-1:ACCOUNT_ID:knowledge-base/KB_ID"
      ]
    },
    {
      "Sid": "S3DocumentBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws-us-gov:s3:::DOCUMENT_BUCKET",
        "arn:aws-us-gov:s3:::DOCUMENT_BUCKET/*"
      ]
    },
    {
      "Sid": "SecretsManagerConnectorTokens",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:ACCOUNT_ID:secret:chatbot/github-pat-*",
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:ACCOUNT_ID:secret:chatbot/jira-pat-*",
        "arn:aws-us-gov:secretsmanager:us-gov-west-1:ACCOUNT_ID:secret:chatbot/confluence-pat-*"
      ]
    }
  ]
}
