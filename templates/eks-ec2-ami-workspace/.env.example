# ── Required ─────────────────────────────────────────────────────────────────
AMI_ID=ami-0123456789abcdef0
SUBNET_ID=subnet-0123456789abcdef0
INSTANCE_TYPE=t3.medium

# ── OS and region ─────────────────────────────────────────────────────────────
OS_TYPE=linux
AWS_REGION=us-gov-west-1

# ── Networking ────────────────────────────────────────────────────────────────
# vpc_id is auto-derived from subnet_id; set explicitly if needed
VPC_ID=
# Public IP only needed if no NAT gateway / private routing to Coder server
ASSOCIATE_PUBLIC_IP=false

# ── Optional key pair (for out-of-band SSH inspection, not required for Coder)
KEY_NAME=

# ── IAM instance profile (recommended: allows SSM, app-level AWS API access)
INSTANCE_PROFILE_NAME=

# ── Storage ────────────────────────────────────────────────────────────────────
ROOT_VOLUME_SIZE_GB=30
ROOT_VOLUME_TYPE=gp3
HOME_VOLUME_SIZE_GB=50
HOME_VOLUME_TYPE=gp3
HOME_VOLUME_IOPS=3000
HOME_DEVICE_NAME=/dev/xvdh

# ── Enterprise proxy (optional) ───────────────────────────────────────────────
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=169.254.169.254,169.254.170.2,localhost,127.0.0.1

# ── Extra user-data commands (runs before Coder agent on Linux) ───────────────
USER_DATA_EXTRA=

# ── Linux desktop over RDP via XRDP (optional) ──────────────────────────────
ENABLE_XRDP=false
XRDP_PORT=3389

# ── MCP: Filesystem ───────────────────────────────────────────────────────────
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project

# ── MCP: GitHub ───────────────────────────────────────────────────────────────
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main
