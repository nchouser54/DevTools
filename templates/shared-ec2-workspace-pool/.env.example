# Shared EC2 host pool workspace identity
WORKSPACE_NAME=shared-ec2-workspace-pool
WORKSPACE_OWNER=platform-team
WORKSPACE_PROFILE=python
WORKSPACE_SIZE=medium

# Docker runtime for shared host pools
SOCKET=unix:///var/run/docker.sock
WORKDIR=/home/coder/project
ENABLE_CODE_SERVER=true

# Profile image catalog
IMAGE_PYTHON=mcr.microsoft.com/devcontainers/python:1-3.12-bookworm
IMAGE_CLAUDE=codercom/example-universal:ubuntu
IMAGE_DEVSECOPS=codercom/example-universal:ubuntu

# Optional repository bootstrap
GIT_REPO_URL=
GIT_REPO_BRANCH=main
VSCODE_EXTENSIONS_CSV=

# Optional MCP baseline
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main
