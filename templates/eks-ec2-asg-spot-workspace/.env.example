# AWS GovCloud Region
AWS_REGION=us-gov-west-1

# VPC & Networking
SUBNET_ID=subnet-xxxxx
VPC_ID=vpc-xxxxx

# AMI & Instance Configuration
AMI_ID=ami-xxxxx
INSTANCE_TYPE=t3.medium
OS_TYPE=linux

# Workspace Metadata
WORKSPACE_NAME=dev-workspace
WORKSPACE_OWNER=developer@example.com

# Auto Scaling Group Settings
ASG_MIN_SIZE=1
ASG_MAX_SIZE=1
ASG_DESIRED_CAPACITY=1
SPOT_INSTANCE_POOLS=2
SPOT_MAX_PRICE=

# EBS Configuration (persistent home)
HOME_VOLUME_SIZE_GB=50
HOME_VOLUME_IOPS=3000
HOME_DEVICE_NAME=/dev/xvdh

# Optional: IAM Instance Profile
INSTANCE_PROFILE_NAME=

# Optional: EC2 Key Pair (for out-of-band SSH)
KEY_NAME=

# Optional: Enterprise Proxy (for isolated VPCs)
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=169.254.169.254,169.254.170.2,localhost,127.0.0.1

# Optional: Linux Desktop via XRDP
ENABLE_XRDP=false
XRDP_PORT=3389

# Optional: MCP Configuration
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main
