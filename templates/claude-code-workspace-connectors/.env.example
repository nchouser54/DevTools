# Docker runtime
SOCKET=unix:///var/run/docker.sock
CONTAINER_IMAGE=codercom/example-universal:ubuntu
WORKDIR=/home/coder/project
ENABLE_CODE_SERVER=true

# Optional repository bootstrap
GIT_REPO_URL=
GIT_REPO_BRANCH=main
VSCODE_EXTENSIONS_CSV=

# Claude authentication (use one or login manually later)
CLAUDE_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_VERSION=latest
INSTALL_VIA_NPM=false
CLAUDE_MODEL=
PERMISSION_MODE=plan

# Bedrock mode (primary auth path should be IAM role/default AWS credential chain)
ENABLE_BEDROCK=true
AWS_REGION=us-gov-west-1
AWS_BEARER_TOKEN_BEDROCK=

# Enterprise network proxy (optional)
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=

# Optional MCP configuration
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project

ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main

ENABLE_MCP_JIRA=false
MCP_JIRA_SERVER_URL=https://jira.example.mil/mcp
MCP_JIRA_PROJECT_KEY=TEAM
MCP_JIRA_USER_EMAIL=
MCP_JIRA_TOKEN=

ENABLE_MCP_CONFLUENCE=false
MCP_CONFLUENCE_SERVER_URL=https://confluence.example.mil/mcp
MCP_CONFLUENCE_SPACE_KEY=ENG
MCP_CONFLUENCE_USER_EMAIL=
MCP_CONFLUENCE_TOKEN=

MCP_REMOTE_CONFIG_URLS_CSV=
