{
  "name": "EKS Bedrock Chatbot Connectors",
  "slug": "eks-bedrock-chatbot-connectors",
  "description": "Bedrock-powered chatbot on Amazon EKS with pre-wired GitHub, Jira, and Confluence MCP connectors. Extends the starter template with unified tool-routing and per-connector feature flags.",
  "owner": "Rocket City Defense Solutions LLC",
  "version": "0.1.0",
  "runtime": {
    "language": "python",
    "pythonVersion": "3.12",
    "baseImage": "python:3.12-slim-bookworm"
  },
  "platform": {
    "target": "amazon-eks",
    "irsaRequired": true,
    "helmChart": "helm/",
    "k8sManifests": "k8s/"
  },
  "aws": {
    "services": ["bedrock", "iam", "eks", "secretsmanager"],
    "bedrockModel": "replace-with-govcloud-sonnet-4.5-model-id",
    "converse": true,
    "region": "${AWS_REGION}"
  },
  "connectors": {
    "github": {
      "enabled": false,
      "mcpServer": "@modelcontextprotocol/server-github",
      "requiredSecrets": ["GITHUB_PERSONAL_ACCESS_TOKEN"],
      "targetInputs": ["GITHUB_SERVER_URL", "GITHUB_REPOSITORY", "GITHUB_BRANCH"]
    },
    "jira": {
      "enabled": false,
      "mcpServer": "mcp-atlassian",
      "requiredSecrets": ["JIRA_API_TOKEN", "JIRA_USER_EMAIL"],
      "targetInputs": ["JIRA_SERVER_URL", "JIRA_PROJECT_KEY"]
    },
    "confluence": {
      "enabled": false,
      "mcpServer": "mcp-atlassian",
      "requiredSecrets": ["CONFLUENCE_API_TOKEN", "CONFLUENCE_USER_EMAIL"],
      "targetInputs": ["CONFLUENCE_SERVER_URL", "CONFLUENCE_SPACE_KEY"]
    }
  },
  "mcp": {
    "mode": "preconfigured-examples",
    "configPath": "mcp/servers.example.json",
    "notes": "Enable connectors one at a time. Review token scopes before enabling in production."
  },
  "tags": [
    "coder",
    "python",
    "aws",
    "bedrock",
    "eks",
    "chatbot",
    "irsa",
    "mcp",
    "github",
    "jira",
    "confluence",
    "connectors"
  ]
}
