# Workspace identity
WORKSPACE_NAME=eks-bedrock-chatbot-connectors
WORKSPACE_OWNER=platform-team

# AWS configuration (GovCloud primary)
AWS_REGION=us-gov-west-1
AWS_ACCOUNT_ID=replace-me

# Bedrock primary model (set to your actual GovCloud Sonnet 4.5 model ID)
BEDROCK_MODEL_ID=replace-with-govcloud-sonnet-4.5-model-id

# IRSA
IRSA_ROLE_ARN=arn:aws:iam::replace-me:role/eks-bedrock-chatbot-role

# EKS cluster
EKS_CLUSTER_NAME=replace-me
K8S_NAMESPACE=chatbot

# MCP base
MCP_ALLOWED_ROOT=/app
MCP_ENABLE_FILESYSTEM=true
ALLOW_CONNECTOR_WRITES=false

# GitHub connector (disabled by default)
MCP_ENABLE_GITHUB=false
GITHUB_SERVER_URL=https://github.com
GITHUB_REPOSITORY=owner/repo
GITHUB_BRANCH=main
GITHUB_PERSONAL_ACCESS_TOKEN=replace-me

# Jira connector (disabled by default)
MCP_ENABLE_JIRA=false
JIRA_SERVER_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=TEAM
JIRA_API_TOKEN=replace-me
JIRA_USER_EMAIL=you@example.com

# Confluence connector (disabled by default)
MCP_ENABLE_CONFLUENCE=false
CONFLUENCE_SERVER_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=ENG
CONFLUENCE_API_TOKEN=replace-me
CONFLUENCE_USER_EMAIL=you@example.com
