# Docker runtime
SOCKET=unix:///var/run/docker.sock
CONTAINER_IMAGE=codercom/example-universal:ubuntu
WORKDIR=/home/coder/project
ENABLE_CODE_SERVER=true

# Optional repository bootstrap (MCP setup is independent of git repo)
GIT_REPO_URL=
GIT_REPO_BRANCH=main
VSCODE_EXTENSIONS_CSV=

# Claude authentication (choose one or leave blank to login manually later)
CLAUDE_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_VERSION=latest
INSTALL_VIA_NPM=false
CLAUDE_MODEL=
PERMISSION_MODE=plan

# Bedrock mode (primary auth path: IAM role / default AWS credential chain)
ENABLE_BEDROCK=true
AWS_REGION=us-gov-west-1
AWS_BEARER_TOKEN_BEDROCK=

# Enterprise proxy (optional)
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=

# ── MCP: Filesystem (on by default; no credentials needed) ──────────────────
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project

# ── MCP: GitHub ──────────────────────────────────────────────────────────────
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main

# ── MCP: Jira ────────────────────────────────────────────────────────────────
# Atlassian Cloud:   https://mcp.atlassian.com/v1/sse
# Self-hosted:       https://jira.example.com/mcp
ENABLE_MCP_JIRA=false
MCP_JIRA_SERVER_URL=https://jira.example.com/mcp
MCP_JIRA_TOKEN=
MCP_JIRA_PROJECT_KEY=PROJ
MCP_JIRA_USER_EMAIL=

# ── MCP: Confluence ──────────────────────────────────────────────────────────
# Atlassian Cloud:   https://mcp.atlassian.com/v1/sse
# Self-hosted:       https://confluence.example.com/mcp
ENABLE_MCP_CONFLUENCE=false
MCP_CONFLUENCE_SERVER_URL=https://confluence.example.com/mcp
MCP_CONFLUENCE_TOKEN=
MCP_CONFLUENCE_SPACE_KEY=ENG
MCP_CONFLUENCE_USER_EMAIL=

# ── MCP: Custom Scripts ───────────────────────────────────────────────────────
# Comma-separated: server-name:/abs/path/to/script.sh
# Example: my-tool:/opt/mcp/my-tool.sh,audit-log:/opt/mcp/audit.sh
MCP_CUSTOM_SCRIPTS_CSV=

# ── MCP: Remote Config URLs ───────────────────────────────────────────────────
# Comma-separated HTTPS URLs returning { "mcpServers": { ... } } JSON
MCP_REMOTE_CONFIG_URLS_CSV=
