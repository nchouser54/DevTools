# Target EC2 instance
EC2_INSTANCE_ID=i-0123456789abcdef0
OS_TYPE=linux
ARCH=amd64

# AWS region
AWS_REGION=us-gov-west-1

# Working directory on the EC2
CODER_WORKDIR=/home/coder

# Linux: optional OS user to run the agent as (leave blank to run as ssm-user/root)
CODER_USER=coder

# SSM execution timeout (seconds)
SSM_EXECUTION_TIMEOUT_SECONDS=3600

# Linux desktop over RDP via XRDP (optional)
ENABLE_XRDP=false
XRDP_PORT=3389

# MCP: Filesystem (no credentials needed)
ENABLE_MCP_FILESYSTEM=true
MCP_ALLOWED_ROOT=/home/coder/project

# MCP: GitHub (requires a PAT)
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main
