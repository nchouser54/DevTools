# AWS GovCloud Region
AWS_REGION=us-gov-west-1

# VPC & Networking
SUBNET_IDS=subnet-xxxxx,subnet-yyyyy
VPC_ID=vpc-xxxxx

# AMI & Instance Configuration
AMI_ID=ami-xxxxx
INSTANCE_TYPE=t3.medium
OS_TYPE=linux

# Auto Scaling Group Settings
ASG_NAME=asg-infrastructure-workers
ASG_MIN_SIZE=2
ASG_MAX_SIZE=6
ASG_DESIRED_CAPACITY=3

# Spot Configuration
SPOT_INSTANCE_POOLS=3
SPOT_ALLOCATION_STRATEGY=capacity-optimized
SPOT_MAX_PRICE=
ON_DEMAND_PERCENTAGE=20

# Instance Configuration
INSTANCE_PROFILE_NAME=
KEY_NAME=
ASSOCIATE_PUBLIC_IP=false

# Root EBS
ROOT_VOLUME_SIZE_GB=50
ROOT_VOLUME_TYPE=gp3

# Load Balancer (optional)
ENABLE_ALB=false
ALB_SUBNETS=subnet-xxxxx,subnet-yyyyy
ALB_SECURITY_GROUPS=sg-xxxxx

# User Data & Bootstrap
ENABLE_DOCKER=true
ENABLE_SSM=true
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=169.254.169.254,169.254.170.2,localhost,127.0.0.1

# Monitoring & Tagging
ENABLE_CLOUDWATCH_DETAILED=true
ENVIRONMENT=production
PROJECT=infrastructure
COST_CENTER=engineering
