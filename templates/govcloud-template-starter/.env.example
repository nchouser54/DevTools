# GovCloud starter placeholders
# Do not commit real credentials.

WORKSPACE_NAME=govcloud-template-starter
WORKSPACE_OWNER=platform-team
AWS_REGION=us-gov-west-1
DEFAULT_KUBE_NAMESPACE=default
AUTO_CONFIGURE_KUBECONFIG=true

# Optional tooling toggles
ENABLE_HELM=false
HELM_VERSION=v3.16.2
ENABLE_XRDP=false
XRDP_PORT=3389

# Network (optional)
HTTPS_PROXY=
HTTP_PROXY=
NO_PROXY=169.254.169.254,localhost,127.0.0.1

# MCP placeholders
MCP_ALLOWED_ROOT=/workspace
ENABLE_MCP_GITHUB=false
MCP_GITHUB_TOKEN=
MCP_GITHUB_SERVER_URL=https://github.com
MCP_GITHUB_REPOSITORY=owner/repo
MCP_GITHUB_BRANCH=main
