# Workspace identity
WORKSPACE_NAME=eks-kubectl-workspace
WORKSPACE_OWNER=platform-team

# EKS target
AWS_REGION=us-gov-west-1
EKS_CLUSTER_NAME=devtools-cluster
DEFAULT_KUBE_NAMESPACE=default
AUTO_CONFIGURE_KUBECONFIG=true

# Optional Helm install in workspace image bootstrap
ENABLE_HELM=false
HELM_VERSION=v3.16.2

# MCP placeholder
MCP_ALLOWED_ROOT=/workspace
