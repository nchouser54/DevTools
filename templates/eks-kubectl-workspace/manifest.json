{
  "name": "EKS kubectl Workspace",
  "slug": "eks-kubectl-workspace",
  "description": "Coder workspace template for kubectl operations against Amazon EKS with awscli + kubeconfig helper workflow and optional Helm support.",
  "owner": "Rocket City Defense Solutions LLC",
  "version": "0.1.0",
  "inputProfile": {
    "mode": "minimal-first",
    "minimalRequired": [
      "AWS_REGION",
      "EKS_CLUSTER_NAME"
    ],
    "autoDerived": [
      "WORKSPACE_OWNER"
    ],
    "advancedOptional": [
      "DEFAULT_KUBE_NAMESPACE",
      "AUTO_CONFIGURE_KUBECONFIG",
      "ENABLE_HELM",
      "HELM_VERSION"
    ]
  },
  "runtime": {
    "language": "bash",
    "version": "latest",
    "baseImage": "mcr.microsoft.com/devcontainers/base:bookworm"
  },
  "mcp": {
    "mode": "preconfigured-examples",
    "configPath": "mcp/servers.example.json",
    "notes": "Example-only MCP definitions. Operators must review and adapt to their environment."
  },
  "tags": [
    "coder",
    "eks",
    "kubernetes",
    "kubectl",
    "helm",
    "aws",
    "operations",
    "workspace"
  ]
}
